# Enables the requested Google basemap. Restrict this browser key to your site
# and the Maps JavaScript API in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side administration only. Never expose these as NEXT_PUBLIC values.
# Used by npm run admin:audit:research and the state-audit GitHub workflow.
TAVILY_API_KEY=
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/responses
LLM_MODEL=gpt-5-mini
LLM_MAX_TOKENS=4000
LLM_TIMEOUT_MS=300000
# Optional provider-specific value such as none, medium, or high.
LLM_REASONING_EFFORT=

# Legacy fallbacks are also recognized: OPENAI_API_KEY, OPENAI_API_URL,
# and OPENAI_MODEL.
